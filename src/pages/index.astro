---
import Base from '../layouts/Base.astro';
import ProgressBar from '../components/ProgressBar.astro';
import Hero from '../components/Hero.astro';
import ScaleBlock from '../components/ScaleBlock.astro';
import Milestone from '../components/Milestone.astro';
import WealthColumn from '../components/WealthColumn.astro';
import Controls from '../components/Controls.astro';
import Footer from '../components/Footer.astro';
---

<Base>
  <ProgressBar />

  <Hero />

  <Milestone id="m-pixel" theme="red">
    <Fragment slot="card">
      <h2>1 pixel = 1 mês</h2>
    </Fragment>
    <Fragment slot="stage">
      <ScaleBlock cols={1} rows={1} label="1 mês, em tamanho real" />
    </Fragment>
    <Fragment slot="beats">
      <p data-reveal>
        Seu salário: <strong data-dyn="salary">…</strong>. Um mês inteiro cabe nesse pixel.
        Está aí no meio da tela, procura direito.
      </p>
    </Fragment>
  </Milestone>

  <Milestone id="m-ano" theme="yellow">
    <Fragment slot="card">
      <h2>1 ano = 12 pixels</h2>
    </Fragment>
    <Fragment slot="stage">
      <ScaleBlock cols={3} rows={4} label="1 ano (3 × 4), em tamanho real" />
    </Fragment>
    <Fragment slot="beats">
      <p data-reveal>
        Um ano inteiro: <strong data-dyn="year-value">…</strong>. Doze pixels. Só isso.
      </p>
    </Fragment>
  </Milestone>

  <Milestone id="m-familia" theme="red">
    <Fragment slot="card">
      <h2>O que uma família junta na vida inteira</h2>
    </Fragment>
    <Fragment slot="stage">
      <div class="block">
        <div class="block__stage">
          <div class="block__real" data-family-block aria-hidden="true"></div>
        </div>
        <span class="block__caption">patrimônio de uma família, em tamanho real</span>
      </div>
    </Fragment>
    <Fragment slot="beats">
      <p data-reveal>
        Uma família brasileira típica chega aos 65 anos com cerca de
        <strong data-dyn="family-worth">…</strong> de patrimônio. Quase tudo preso na casa própria.
        <span class="beat__fine">
          estimativa: entre <span data-dyn="family-range">…</span> · veja como chegamos nesse
          número em <a href="/referencias">/referencias</a>
        </span>
      </p>
      <p data-reveal>
        E se você guardasse 100% do salário por 47 anos, com todos os reajustes reais?
        <strong data-dyn="life-value">…</strong>. Umas <strong data-dyn="life-vs-family">…</strong>
        a mais. E ainda assim, não chega perto do que vem aí.
      </p>
    </Fragment>
  </Milestone>

  <WealthColumn id="bilhao" endId="fim-bilhao">
    <Fragment slot="intro">
      <p class="col__eyebrow">primeiro marco</p>
      <p class="col__name">R$ 1 bilhão</p>
      <p class="col__context">
        São <strong data-dyn="billion-years">…</strong> de trabalho. A coluna aí embaixo está em
        escala real. Desce.
      </p>
    </Fragment>
    <Fragment slot="end">
      Isso foi só 1 bilhão. Tá só aquecendo.
    </Fragment>
  </WealthColumn>

  <WealthColumn id="richest" endId="fim-mais-rico">
    <Fragment slot="intro">
      <p class="col__eyebrow">a pessoa mais rica do Brasil</p>
      <p class="col__name" data-dyn="richest-name">…</p>
      <p class="col__figure">
        <span data-dyn="richest-usd">…</span> (<span data-dyn="richest-brl">…</span>)
      </p>
      <p class="col__source" data-dyn="richest-wealth-source">…</p>
      <p class="col__source" data-dyn="forbes-source">…</p>
      <p class="col__context">
        Para juntar isso você teria de trabalhar <strong data-dyn="richest-years">…</strong>.
        Antes dos primeiros hominídeos.
      </p>
    </Fragment>
    <Fragment slot="end">
      Fim da fortuna de <strong data-dyn="richest-name">…</strong>:
      <strong data-dyn="richest-lives">…</strong> inteiras de trabalho.
    </Fragment>
  </WealthColumn>

  <WealthColumn id="musk" endId="fim-musk">
    <Fragment slot="intro">
      <p class="col__eyebrow">a pessoa mais rica do mundo</p>
      <p class="col__name" data-dyn="musk-name">…</p>
      <p class="col__figure">
        <span data-dyn="musk-usd">…</span> (<span data-dyn="musk-brl">…</span>)
      </p>
      <p class="col__source" data-dyn="musk-wealth-source">…</p>
      <p class="col__source" data-dyn="world-forbes-source">…</p>
      <p class="col__context">
        São <strong data-dyn="musk-years">…</strong> de trabalho. Boa sorte.
      </p>
    </Fragment>
    <Fragment slot="end">
      Fim. <strong data-dyn="musk-lives">…</strong> inteiras de trabalho. Agora você sabe o
      tamanho da distância.
      <a class="col__end-link" href="/referencias">ver fontes e metodologia → /referencias</a>
    </Fragment>
  </WealthColumn>

  <Footer />

  <Controls />

  <script>
    import { boot, wireScaleInfo } from '../lib/render';
    import { initReveal } from '../lib/reveal';
    wireScaleInfo();
    initReveal();
    boot().catch((err) => console.error('Falha ao carregar os dados:', err));
  </script>
</Base>
