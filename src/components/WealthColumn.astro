---
interface Props {
  id: string;
  endId: string;
}

const { id, endId } = Astro.props;
---

<section class="section section--dark col" data-col-section={id}>
  <div class="wrap">
    <div class="panel col__intro" data-reveal>
      <slot name="intro" />
    </div>
    <a class="col__skip" href={`#${endId}`}>pular para o fim da coluna ↓</a>
  </div>

  <div class="wealth-column wealth-column--metric" data-column={id}></div>

  <div class="wrap">
    <div class="panel col__end" id={endId}>
      <slot name="end" />
    </div>
  </div>
</section>
