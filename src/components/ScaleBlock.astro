---
interface Props {
  cols: number;
  rows: number;
  label: string;
}

const { cols, rows, label } = Astro.props;
---

<div class="block">
  <div class="block__stage">
    <div class="block__real" style={`width:${cols}px;height:${rows}px`} aria-hidden="true"></div>
  </div>
  <span class="block__caption">{label}</span>
</div>
