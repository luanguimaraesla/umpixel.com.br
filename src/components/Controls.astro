---
---

<div class="controls" data-idle role="group" aria-label="Controles de rolagem automática">
  <button
    class="controls__play"
    id="btn-play"
    type="button"
    aria-label="rolar automaticamente"
    aria-pressed="false"
    disabled
  >
    ▶
  </button>
  <select class="controls__select" id="speed-select" aria-label="Velocidade da rolagem" disabled>
    <option value="0.5">0,5×</option>
    <option value="1" selected>1×</option>
    <option value="2">2×</option>
    <option value="3">3×</option>
  </select>
  <span class="controls__readout" data-speed-readout aria-hidden="true"></span>
</div>
<div class="toast" id="toast" role="status" aria-live="polite" hidden></div>
