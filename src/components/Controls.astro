---
---

<div class="controls" role="group" aria-label="Controles de rolagem automática">
  <button
    class="controls__play"
    id="btn-play"
    type="button"
    aria-label="rolar automaticamente"
    aria-pressed="false"
    disabled
  >
    ▶
  </button>
  <div class="controls__speeds" role="group" aria-label="Velocidade da rolagem">
    <button type="button" class="controls__mult" data-mult="0.5" disabled>0,5×</button>
    <button type="button" class="controls__mult" data-mult="1" aria-pressed="true" disabled>1×</button>
    <button type="button" class="controls__mult" data-mult="2" disabled>2×</button>
    <button type="button" class="controls__mult" data-mult="3" disabled>3×</button>
  </div>
  <span class="controls__readout" data-speed-readout aria-hidden="true"></span>
  <span class="controls__pos" data-pos-readout aria-hidden="true"></span>
</div>
<div class="toast" id="toast" role="status" aria-live="polite" hidden></div>
