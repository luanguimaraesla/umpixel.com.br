---
// Hand-drawn brush arrows, one shared visual language across the site (D-V2-10).
// Each variant is a small static SVG: strokes use currentColor so CSS colors it,
// every logical stroke is drawn twice (slightly different width + offset) for an
// inked look, and an feTurbulence + feDisplacementMap filter roughens the edges.
type Variant = 'down' | 'shaft' | 'head' | 'curve';

interface Props {
  variant: Variant;
  class?: string;
}

const { variant, class: className } = Astro.props;

// Unique filter id per instance so several arrows on one page never share a filter.
const uid = Math.random().toString(36).slice(2, 8);
const filterId = `hd-${variant}-${uid}`;

interface Stroke {
  d: string;
  w: number;
  dx?: number;
  dy?: number;
}

const shapes: Record<
  Variant,
  { viewBox: string; preserve: string; base: string; scale: number; strokes: Stroke[] }
> = {
  // Tall arrow with a slight S-curve and a bold head; used by the hero cue.
  down: {
    viewBox: '0 0 60 150',
    preserve: 'xMidYMid meet',
    base: '0.03',
    scale: 4,
    strokes: [
      { d: 'M30 12 C 21 44, 39 80, 30 118', w: 7 },
      { d: 'M30 12 C 23 45, 37 79, 30 118', w: 3.5, dx: 0.8, dy: -0.5 },
      { d: 'M15 98 C 20 108, 26 115, 30 122', w: 7 },
      { d: 'M15 98 C 20 108, 26 115, 30 122', w: 3.5, dx: 0.6, dy: 0.4 },
      { d: 'M45 98 C 40 108, 34 115, 30 122', w: 7 },
      { d: 'M45 98 C 40 108, 34 115, 30 122', w: 3.5, dx: -0.6, dy: 0.4 },
    ],
  },
  // Short comma-like arrow pointing right, like a hand annotation at the CTA.
  curve: {
    viewBox: '0 0 96 60',
    preserve: 'xMidYMid meet',
    base: '0.035',
    scale: 3,
    strokes: [
      { d: 'M10 42 C 27 12, 55 9, 80 26', w: 6 },
      { d: 'M10 42 C 29 14, 53 11, 80 26', w: 3, dx: 0.5, dy: -0.4 },
      { d: 'M67 15 C 73 19, 79 23, 84 27', w: 6 },
      { d: 'M67 15 C 73 19, 79 23, 84 27', w: 3, dx: 0.4, dy: 0.3 },
      { d: 'M69 40 C 75 35, 80 31, 84 27', w: 6 },
      { d: 'M69 40 C 75 35, 80 31, 84 27', w: 3, dx: 0.4, dy: -0.3 },
    ],
  },
  // Mostly-horizontal wavy line in a wide box, meant to be stretched to fill a gap.
  shaft: {
    viewBox: '0 0 200 24',
    preserve: 'none',
    base: '0.02',
    scale: 3,
    strokes: [
      { d: 'M6 12 C 46 6, 86 18, 126 10 S 190 14, 196 11', w: 5 },
      { d: 'M6 12 C 48 7, 84 17, 126 11 S 190 13, 196 11', w: 3, dy: 0.6 },
    ],
  },
  // Small right-pointing brush head that must keep its shape (never stretch).
  head: {
    viewBox: '0 0 34 34',
    preserve: 'xMidYMid meet',
    base: '0.04',
    scale: 2.5,
    strokes: [
      { d: 'M9 8 C 15 11, 22 14, 27 17', w: 6 },
      { d: 'M9 8 C 15 11, 22 14, 27 17', w: 3, dx: 0.4, dy: 0.3 },
      { d: 'M9 26 C 15 23, 22 20, 27 17', w: 6 },
      { d: 'M9 26 C 15 23, 22 20, 27 17', w: 3, dx: 0.4, dy: -0.3 },
    ],
  },
};

const s = shapes[variant];
---

<svg
  class:list={[className]}
  viewBox={s.viewBox}
  preserveAspectRatio={s.preserve}
  fill="none"
  stroke="currentColor"
  stroke-linecap="round"
  stroke-linejoin="round"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <filter id={filterId} x="-25%" y="-25%" width="150%" height="150%">
    <feTurbulence type="fractalNoise" baseFrequency={s.base} numOctaves="2" seed="7" result="noise" />
    <feDisplacementMap
      in="SourceGraphic"
      in2="noise"
      scale={s.scale}
      xChannelSelector="R"
      yChannelSelector="G"
    />
  </filter>
  <g filter={`url(#${filterId})`}>
    {
      s.strokes.map((st) => (
        <path
          d={st.d}
          stroke-width={st.w}
          transform={st.dx || st.dy ? `translate(${st.dx ?? 0} ${st.dy ?? 0})` : undefined}
        />
      ))
    }
  </g>
</svg>
