---
// Measuring line + fixed left cluster (D-V3-2). The line is a full-width 2px rule
// at exactly 50vh (the depth updateScrollUI measures), fading to transparent at
// both edges; it sits below the pinned cards so a card passes over it. The cluster
// stacks a mini scale legend, the live counter (full value + short form), and the
// autoscroll player. render.ts drives text, accent and visibility. The cluster
// reveals at the col-start latch and stays; the line and counter fade when no
// column is under 50vh. The toast lives here too, at the bottom of the viewport.
---

<div class="measure-line" data-measure-line aria-hidden="true"></div>

<div class="cluster" data-cluster data-idle>
  <div class="pos-legend panel" aria-hidden="true">
    <div class="pos-legend__row">
      <span class="pos-legend__swatch">
        <span class="pos-legend__block" style="width:1px;height:1px"></span>
      </span>
      <span class="pos-legend__text">1 mês</span>
    </div>
    <div class="pos-legend__row">
      <span class="pos-legend__swatch">
        <span class="pos-legend__block" style="width:4px;height:3px"></span>
      </span>
      <span class="pos-legend__text">1 ano</span>
    </div>
    <div class="pos-legend__row">
      <span class="pos-legend__swatch">
        <span class="pos-legend__block" style="width:33px;height:32px"></span>
      </span>
      <span class="pos-legend__text">1 vida</span>
    </div>
  </div>

  <div class="pos-counter" data-pos-counter aria-hidden="true">
    <span class="pos-counter__full" data-pos-full></span>
    <span class="pos-counter__short" data-pos-short></span>
  </div>

  <div class="pos-player" role="group" aria-label="Controles de rolagem automática">
    <button
      class="pos-player__play"
      id="btn-play"
      type="button"
      aria-label="rolar automaticamente"
      aria-pressed="false"
      disabled
    >
      ▶
    </button>
    <select class="speed-select" id="speed-select" aria-label="Velocidade da rolagem" disabled>
      <option value="0.5">0,5×</option>
      <option value="1" selected>1×</option>
      <option value="2">2×</option>
      <option value="4">4×</option>
      <option value="8">8×</option>
    </select>
  </div>
</div>

<div class="toast" id="toast" role="status" aria-live="polite" hidden></div>
