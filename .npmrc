# Only install package versions published more than 7 days ago.
# This reduces exposure to malicious freshly-published packages
# (e.g. account-takeover or typosquat supply-chain attacks), which
# are typically caught and removed within a few days of release.
# See: https://docs.npmjs.com/cli/v11/using-npm/config#min-release-age
min-release-age=7
